<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App only uses HTTPS / standard Apple crypto. Declaring this as
	     false skips the "Export Compliance" question on every TestFlight
	     upload. (Set to true only if you add custom encryption later.) -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.radsoftinc.PhotoAura.deeplink</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>aura</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
